# ─── Frontend (React / CRA) ────────────────────────────────────────────────────
# This project is 100% Supabase — there is no custom backend server.
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Used only by the AI Advisor's document-upload validation on the client.
# The actual Gemini API key lives server-side as a Supabase Edge Function
# secret (GOOGLE_API_KEY) — see supabase/functions/gemini-proxy — and must
# never be set with the REACT_APP_ prefix, since that would bundle it into
# the browser build.
